# ============================================================================
# Spendy — Local environment variables
#
# Copy this file to `.env`, fill in the values below, then run
# `npm run build:config` to inject them into assets/js/utils/config.js.
#
# Only PUBLIC values belong in this file — everything here ends up in the
# browser bundle. Never add OPENAI_API_KEY or SUPABASE_SERVICE_ROLE_KEY
# here; those are server-only secrets set via `supabase secrets set ...`
# for the Edge Functions (see README § "Deploy the AI Edge Functions").
# ============================================================================

# Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://xzltepxmaedhevwvsnjt.supabase.co

# Supabase → Project Settings → API → Project API keys → anon / public
# Safe to expose in the browser: row-level security enforces data access,
# not secrecy of this key.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh6bHRlcHhtYWVkaGV2d3Zzbmp0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1MDI2OTgsImV4cCI6MjA5OTA3ODY5OH0.rzYaBi12lGu9XovMTvFRsiDXl26UT5Ch2sTbwLCz8ao

# Optional — used by scripts/inject-env.js, defaults to "production" if unset.
NODE_ENV=development
