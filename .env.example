# ============================================================================
# Spendy — Environment Variables
# Copy to .env for local dev (`npm run build:config` reads it via your shell,
# or use `vercel env pull`). In production, set these in the Vercel dashboard
# under Project Settings → Environment Variables.
# ============================================================================

# Public — safe to ship to the browser (protected by RLS, not secrecy)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER exposed to the browser. Set these only in:
#   1. Vercel's Environment Variables (used by nothing client-side)
#   2. Supabase Edge Function secrets: `supabase secrets set OPENAI_API_KEY=...`
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key

NODE_ENV=production
